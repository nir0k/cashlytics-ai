# ============================================
# Cashlytics Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# --------------------------------------------
# Database Configuration (Required)
# --------------------------------------------
# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For Docker Compose: use 'postgres' as host (internal network)
DATABASE_URL=postgresql://cashlytics:your_secure_password@postgres:5432/cashlytics

# PostgreSQL password (used by the postgres container)
# IMPORTANT: Change this to a secure random password!
POSTGRES_PASSWORD=your_secure_password

# --------------------------------------------
# Application Configuration (Required)
# --------------------------------------------
# Public URL where Cashlytics will be accessible
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------
# AI Assistant Configuration (Optional)
# --------------------------------------------
# OpenAI API key for the AI-powered financial assistant
# Without this key, the AI Assistant feature will be disabled
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# --------------------------------------------
# Authentication Configuration (Required)
# --------------------------------------------
# Auth.js secret for JWT encryption
# Generate with: npx auth secret
# Or use: openssl rand -base64 32
AUTH_SECRET=

# Trust the request host — required when accessing via IP address or custom domain
# Set to true for any non-localhost deployment (VPS, reverse proxy, Docker)
AUTH_TRUST_HOST=true

# --------------------------------------------
# Registration Mode (Required for production)
# --------------------------------------------
# Controls whether new users can register.
#
# SINGLE_USER_MODE=true  — Registration is open only for the first user.
#   Once one user exists, /register redirects to /login and registerAction
#   returns an error. Intended for personal/self-hosted single-person deployments.
#
# SINGLE_USER_MODE=false (or omit) — Open registration. Any visitor can
#   create an account. Intended for shared/family/team deployments.
#
# WARNING: "false" must be the exact string — not omitting the variable.
#   If set to "false", registration remains open. If omitted, same result.
SINGLE_USER_MODE=true

# Email address of the owner in single-user mode.
# Used during data migration (see: backfill script) to assign existing
# records to this user. Must match the email used when first registering.
# Not used as a registration whitelist — any email can register as the first user.
SINGLE_USER_EMAIL=you@example.com

# --------------------------------------------
# SMTP Configuration (Optional)
# --------------------------------------------
# Configure SMTP to enable email features (password reset, welcome emails)
# Without SMTP, the app works but email features are disabled

# Email transport method: "smtp" or "sendmail"
# - smtp: Use external SMTP server (requires SMTP_HOST, SMTP_PORT, etc.)
# - sendmail: Use local sendmail binary (requires Postfix/Exim installed)
# EMAIL_TRANSPORT=smtp

# SMTP server hostname (e.g., smtp.gmail.com, smtp.sendgrid.net)
# SMTP_HOST=smtp.example.com

# SMTP port (587 for STARTTLS, 465 for implicit TLS)
# SMTP_PORT=587

# SMTP authentication username
# SMTP_USER=your-email@example.com

# SMTP authentication password or app-specific password
# SMTP_PASS=your-smtp-password

# From address for outgoing emails (defaults to SMTP_USER if not set)
# SMTP_FROM=noreply@example.com

# Server-side app URL for generating email links (password reset, etc.)
# Required if SMTP is configured - used to build absolute URLs in emails
# If not set, defaults to NEXT_PUBLIC_APP_URL
# APP_URL=https://your-domain.com

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=<generated_public_key>
VAPID_PRIVATE_KEY=<generated_private_key>
VAPID_SUBJECT=mailto:info@aaronjoel.de
CRON_SECRET=                # Generate: openssl rand -hex 32

# --------------------------------------------
# Production Tips
# --------------------------------------------
# 1. Use strong, unique passwords for POSTGRES_PASSWORD
# 2. Set NEXT_PUBLIC_APP_URL to your actual domain or IP
# 3. Only set OPENAI_API_KEY if you want AI features
# 4. Generate AUTH_SECRET with: npx auth secret
# 5. Never commit .env to version control
# 6. Set AUTH_TRUST_HOST=true for any non-localhost deployment