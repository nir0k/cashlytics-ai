# ============================================
# Cashlytics Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# --------------------------------------------
# Database Configuration (Required)
# --------------------------------------------
# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For Docker Compose: use 'postgres' as host (internal network)
DATABASE_URL=postgresql://cashlytics:your_secure_password@postgres:5432/cashlytics

# PostgreSQL password (used by the postgres container)
# IMPORTANT: Change this to a secure random password!
POSTGRES_PASSWORD=your_secure_password

# --------------------------------------------
# Application Configuration (Required)
# --------------------------------------------
# Public URL where Cashlytics will be accessible
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------
# AI Assistant Configuration (Optional)
# --------------------------------------------
# OpenAI API key for the AI-powered financial assistant
# Without this key, the AI Assistant feature will be disabled
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# --------------------------------------------
# Authentication Configuration (Required)
# --------------------------------------------
# Auth.js secret for JWT encryption
# Generate with: npx auth secret
# Or use: openssl rand -base64 32
AUTH_SECRET=

# --------------------------------------------
# Production Tips
# --------------------------------------------
# 1. Use strong, unique passwords for POSTGRES_PASSWORD
# 2. Set NEXT_PUBLIC_APP_URL to your actual domain
# 3. Only set OPENAI_API_KEY if you want AI features
# 4. Generate AUTH_SECRET with: npx auth secret
# 5. Never commit .env to version control